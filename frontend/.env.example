# Environment Variables for SRI KANNAN TRADERS Frontend

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Application Configuration
REACT_APP_NAME=SRI KANNAN TRADERS
REACT_APP_VERSION=1.0.0

# UI Configuration
REACT_APP_DEFAULT_CURRENCY=₹
REACT_APP_DATE_FORMAT=dd/MM/yyyy

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DATASET_UPLOAD=true
